{
  "outputDirectory": "Serializer",
  "logLevel": "info",
  "dryRun": false,
  "conflictStrategy": "source-wins",
  "predicates": [
    {
      "name": "Content - Swift 2 (deployment)",
      "providerType": "Content",
      "areaId": 3,
      "path": "/",
      "excludes": [
        "/Home",
        "/Home Machines",
        "/About",
        "/Posts",
        "/New Serialized Page"
      ],
      "serviceCaches": [],
      "excludeFields": [
        "AreaDomain",
        "AreaDomainLock",
        "AreaNoindex",
        "AreaNofollow",
        "AreaRobotsTxt",
        "AreaRobotsTxtIncludeSitemap",
        "GoogleTagManagerID"
      ],
      "excludeXmlElements": [
        "EmptyCartRedirectPage",
        "ShoppingCartLink"
      ],
      "excludeAreaColumns": [
        "AreaCdnHost",
        "AreaCookieWarningTemplate"
      ]
    },
    {
      "name": "EcomCountries",
      "providerType": "SqlTable",
      "table": "EcomCountries",
      "serviceCaches": [
        "Dynamicweb.Ecommerce.International.CountryRelationService",
        "Dynamicweb.Ecommerce.International.CountryService"
      ]
    },
    {
      "name": "EcomCountryText",
      "providerType": "SqlTable",
      "table": "EcomCountryText",
      "serviceCaches": [
        "Dynamicweb.Ecommerce.International.CountryService"
      ]
    },
    {
      "name": "EcomCurrencies",
      "providerType": "SqlTable",
      "table": "EcomCurrencies",
      "serviceCaches": [
        "Dynamicweb.Ecommerce.International.CurrencyService"
      ]
    },
    {
      "name": "EcomLanguages",
      "providerType": "SqlTable",
      "table": "EcomLanguages",
      "serviceCaches": [
        "Dynamicweb.Ecommerce.International.LanguageService",
        "Dynamicweb.SystemTools.TranslationLanguageService"
      ]
    },
    {
      "name": "EcomVatGroups",
      "providerType": "SqlTable",
      "table": "EcomVatGroups",
      "nameColumn": "VatName",
      "serviceCaches": [
        "Dynamicweb.Ecommerce.International.VatGroupCountryRelationService",
        "Dynamicweb.Ecommerce.International.VatGroupService"
      ]
    },
    {
      "name": "EcomVatCountryRelations",
      "providerType": "SqlTable",
      "table": "EcomVatCountryRelations",
      "serviceCaches": [
        "Dynamicweb.Ecommerce.International.VatGroupCountryRelationService",
        "Dynamicweb.Ecommerce.International.VatGroupService"
      ]
    },
    {
      "name": "EcomShops",
      "providerType": "SqlTable",
      "table": "EcomShops",
      "excludeFields": [
        "ShopAutoId",
        "ShopCreated"
      ],
      "serviceCaches": []
    },
    {
      "name": "EcomShopLanguageRelation",
      "providerType": "SqlTable",
      "table": "EcomShopLanguageRelation",
      "serviceCaches": []
    },
    {
      "name": "EcomShopGroupRelation",
      "providerType": "SqlTable",
      "table": "EcomShopGroupRelation",
      "serviceCaches": []
    },
    {
      "name": "EcomPayments",
      "providerType": "SqlTable",
      "table": "EcomPayments",
      "xmlColumns": [
        "PaymentGatewayParameters",
        "PaymentCheckoutParameters"
      ],
      "excludeFields": [
        "PaymentAutoId"
      ],
      "serviceCaches": [
        "Dynamicweb.Ecommerce.Orders.PaymentService"
      ]
    },
    {
      "name": "EcomShippings",
      "providerType": "SqlTable",
      "table": "EcomShippings",
      "xmlColumns": [
        "ShippingServiceParameters"
      ],
      "excludeFields": [
        "ShippingAutoId"
      ],
      "serviceCaches": [
        "Dynamicweb.Ecommerce.Orders.ShippingService"
      ]
    },
    {
      "name": "EcomMethodCountryRelation",
      "providerType": "SqlTable",
      "table": "EcomMethodCountryRelation",
      "serviceCaches": [
        "Dynamicweb.Ecommerce.Orders.PaymentService",
        "Dynamicweb.Ecommerce.Orders.ShippingService"
      ]
    },
    {
      "name": "EcomOrderFlow",
      "providerType": "SqlTable",
      "table": "EcomOrderFlow",
      "nameColumn": "OrderFlowName",
      "serviceCaches": []
    },
    {
      "name": "EcomOrderStates",
      "providerType": "SqlTable",
      "table": "EcomOrderStates",
      "nameColumn": "OrderStateName",
      "serviceCaches": []
    },
    {
      "name": "EcomOrderStateRules",
      "providerType": "SqlTable",
      "table": "EcomOrderStateRules",
      "serviceCaches": []
    },
    {
      "name": "UrlPath",
      "providerType": "SqlTable",
      "table": "UrlPath",
      "serviceCaches": []
    }
  ],
  "excludeFieldsByItemType": {},
  "excludeXmlElementsByType": {
    "Dynamicweb.Ecommerce.Frontend.UrlHandling.ShopUrlDataProvider, Dynamicweb.Ecommerce": [],
    "eCom_CartV2": [],
    "eCom_Catalog": [],
    "eCom_ContextOrderRenderer": [],
    "eCom_CustomerExperienceCenter": [],
    "eCom_CustomerExperienceCenterFavorites": [],
    "eCom_CustomerExperienceCenterSavedCards": [],
    "eCom_IntegrationCustomerCenter": [],
    "eCom_ProductCatalog": [],
    "QueryPublisher": [],
    "UserAddresses": [],
    "UserAuthentication": [],
    "UserChangePassword": [],
    "UserCreate": [],
    "UserEdit": [],
    "UserForgotPassword": [],
    "UserGroups": [],
    "UserManagementFrontend": [],
    "UserView": []
  },
  "serializeRoot": "Serializer\\SerializeRoot",
  "uploadDir": "Serializer\\Upload",
  "downloadDir": "Serializer\\Download",
  "logDir": "Serializer\\Log"
}
